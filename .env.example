# ===========================================
# AI Code Quality Assistant - 环境变量配置
# ===========================================

# 应用配置
APP_NAME=AICodeQualityAssistant
APP_ENV=development  # development, staging, production
DEBUG=true
VERSION=1.0.0

# 后端服务配置
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
WORKERS=4

# 前端配置
FRONTEND_PORT=3000
VITE_API_BASE_URL=http://localhost:8000/api/v1

# 数据库配置
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ai_code_quality
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123
POSTGRES_ECHO=false

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# MinIO配置 (对象存储)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=ai-code-quality-reports
MINIO_SECURE=false

# JWT配置
SECRET_KEY=your-super-secret-jwt-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# LLM API配置
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4
CLAUDE_API_KEY=your-claude-api-key
CLAUDE_MODEL=claude-3-sonnet-20240229

# 代码分析配置
MAX_FILE_SIZE_MB=10
SUPPORTED_LANGUAGES=python,javascript,typescript,java,go,rust,c++,csharp
ANALYSIS_TIMEOUT_SECONDS=300

# 日志配置
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR
LOG_FORMAT=json
LOG_FILE=logs/app.log

# 监控配置
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# 邮件配置 (可选)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=AICodeQuality <noreply@aicodequality.dev>

# 安全配置
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
RATE_LIMIT_PER_MINUTE=100

# 文件上传配置
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=50
ALLOWED_FILE_EXTENSIONS=.py,.js,.ts,.java,.go,.rs,.cpp,.cs,.md,.txt