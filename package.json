{
  "name": "ai-code-quality-assistant",
  "version": "1.0.0",
  "description": "智能代码质量分析与优化助手",
  "keywords": ["ai", "code-quality", "static-analysis", "llm", "refactoring"],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.ts,.jsx,.tsx --fix",
    "format": "prettier --write \"src/**/*.{vue,js,ts,jsx,tsx,json,css,scss,md}\"",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "vue": "^3.3.8",
    "vue-router": "^4.2.5",
    "pinia": "^2.1.7",
    "axios": "^1.6.2",
    "element-plus": "^2.4.1",
    "echarts": "^5.4.3",
    "@element-plus/icons-vue": "^2.1.0",
    "dayjs": "^1.11.10",
    "lodash-es": "^4.17.21",
    "vue3-lazyload": "^0.2.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^4.5.0",
    "vite": "^5.0.0",
    "typescript": "^5.2.2",
    "@types/node": "^20.9.1",
    "@types/lodash-es": "^4.17.9",
    "@vue/eslint-config-typescript": "^12.0.0",
    "eslint": "^8.53.0",
    "eslint-plugin-vue": "^9.17.0",
    "prettier": "^3.1.0",
    "sass": "^1.69.5",
    "vitest": "^1.0.0",
    "@vue/test-utils": "^2.4.1",
    "jsdom": "^22.1.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "volta": {
    "node": "18.18.2",
    "npm": "10.2.0"
  }
}